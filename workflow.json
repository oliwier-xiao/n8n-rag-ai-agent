    {
      "parameters": {
        "jsCode": "// Pobierz strukturę drzewa z poprzedniego węzła HTTP Request\nconst tree = $input.first().json.tree;\n\n// Filtrujemy pliki\nconst filteredFiles = tree.filter(item => {\n  if (item.type !== 'blob') return false;\n  if (!item.path.endsWith('.md')) return false;\n  if (!item.path.startsWith('docs/') && item.path !== 'README.md') {\n      return false;\n  }\n  return true;\n});\n\nreturn filteredFiles.map(item => ({ json: item }));"
      },
